# Gmail Test Account Credentials
# Set these as environment variables before running the tests.
# NEVER commit real credentials to version control.
#
# On macOS/Linux:
#   export GMAIL_EMAIL="your-test-email@gmail.com"
#   export GMAIL_PASSWORD="your-test-password"
#
# On Windows (cmd):
#   set GMAIL_EMAIL=your-test-email@gmail.com
#   set GMAIL_PASSWORD=your-test-password
#
# Alternatively, you can pass them as system properties:
#   mvn test -Dgmail.email="your-test-email@gmail.com" -Dgmail.password="your-test-password"

GMAIL_EMAIL=adyarofa@gmail.com
GMAIL_PASSWORD=your-test-password
